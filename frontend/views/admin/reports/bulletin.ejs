<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Bulletin - <%= student.name %>
    </title>
    <style>
        body {
            font-family: 'Times New Roman', serif;
            padding: 20px;
        }

        .header {
            text-align: center;
            margin-bottom: 30px;
            border-bottom: 2px solid #000;
            padding-bottom: 10px;
        }

        .school-info {
            font-size: 1.2rem;
            font-weight: bold;
            text-transform: uppercase;
        }

        .student-info {
            display: flex;
            justify-content: space-between;
            margin-bottom: 20px;
        }

        .student-info div {
            flex: 1;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 20px;
        }

        th,
        td {
            border: 1px solid #000;
            padding: 8px;
            text-align: center;
        }

        th {
            background: #f0f0f0;
        }

        .subject-name {
            text-align: left;
        }

        .summary {
            margin-top: 20px;
            text-align: right;
            font-size: 1.1rem;
        }

        .footer {
            margin-top: 50px;
            display: flex;
            justify-content: space-around;
        }

        @media print {
            .no-print {
                display: none;
            }
        }
    </style>
</head>

<body>
    <div class="no-print" style="margin-bottom: 20px;">
        <button onclick="window.print()">Print Bulletin</button>
    </div>

    <div class="header">
        <div class="school-info">Meshbi School</div>
        <div>School Management System</div>
        <div>Academic Year: 2025/2026</div>
        <h3>OFFICIAL REPORT CARD</h3>
        <h4>Semester <%= semester %>
        </h4>
    </div>

    <div class="student-info">
        <div>
            <strong>Name:</strong>
            <%= student.name %><br>
                <strong>Matricule:</strong>
                <%= student.matricule %><br>
                    <strong>Gender:</strong>
                    <%= student.gender %>
        </div>
        <div style="text-align: right;">
            <strong>Class/Level:</strong>
            <%= student.level %><br>
                <strong>Date Generated:</strong>
                <%= new Date().toLocaleDateString() %>
        </div>
    </div>

    <table>
        <thead>
            <tr>
                <th class="subject-name">Subject</th>
                <th>Coeff</th>
                <th>Seq 1</th>
                <th>Seq 2</th>
                <th>Avg /20</th>
                <th>Points (Avg * Coeff)</th>
                <th>Teacher</th>
            </tr>
        </thead>
        <tbody>
            <% results.forEach(row=> { %>
                <tr>
                    <td class="subject-name">
                        <%= row.name %>
                    </td>
                    <td>
                        <%= row.coefficient %>
                    </td>
                    <td>
                        <%= row.seq1 %>
                    </td>
                    <td>
                        <%= row.seq2 %>
                    </td>
                    <td>
                        <%= row.subjectAvg.toFixed(2) %>
                    </td>
                    <td>
                        <%= row.weightedPoint.toFixed(2) %>
                    </td>
                    <td>
                        <%= row.teacher_name || '-' %>
                    </td>
                </tr>
                <% }) %>
        </tbody>
        <tfoot>
            <tr style="font-weight: bold; background: #f9f9f9;">
                <td class="subject-name">TOTAL</td>
                <td>
                    <%= summary.totalCoeff %>
                </td>
                <td>-</td>
                <td>-</td>
                <td>-</td>
                <td>
                    <%= summary.totalPoints.toFixed(2) %>
                </td>
                <td>-</td>
            </tr>
        </tfoot>
    </table>

    <div class="summary">
        <p><strong>Semester Average: <%= summary.semesterAvg.toFixed(2) %> / 20</strong></p>
    </div>

    <div class="footer">
        <div>
            <strong>The Teacher</strong>
            <br><br><br>
            ________________
        </div>
        <div>
            <strong>The Principal</strong>
            <br><br><br>
            ________________
        </div>
    </div>

</body>

</html>