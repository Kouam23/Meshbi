<%- include('../../partials/header', { user: user }) %>

    <div class="main-content">
        <div class="page-header">
            <h2>Edit Subject</h2>
            <a href="/subjects" class="btn-secondary">
                <%= t.back %>
            </a>
        </div>

        <div class="glass-card form-container" style="max-width:600px; margin:0 auto;">
            <form action="/subjects/<%= subject.id %>/edit" method="POST">
                <div class="form-group">
                    <label>
                        <%= t.subject_name %> *
                    </label>
                    <input type="text" name="name" required placeholder="ex. Mathematics" value="<%= subject.name %>">
                </div>
                <div class="form-group">
                    <label>
                        <%= t.subject_code %>
                    </label>
                    <input type="text" name="code" placeholder="ex. MATH" value="<%= subject.code || '' %>">
                </div>
                <div class="form-group">
                    <label>
                        <%= t.subject_coeff %>
                    </label>
                    <input type="number" name="coefficient" value="<%= subject.coefficient || 1 %>" min="1" max="10">
                </div>
                <div class="form-group">
                    <label>
                        <%= t.subject_level %> *
                    </label>
                    <select name="level" required>
                        <option value="">
                            <%= t.student_level_select %>
                        </option>
                        <% ['Level 1','Level 2','Level 3','Level 4','Master 1','Master 2','Doctorate'].forEach(l=> { %>
                            <option value="<%= l %>" <%= subject.level === l ? 'selected' : '' %>>
                                <%= l %>
                            </option>
                            <% }) %>
                    </select>
                </div>
                <div class="form-group">
                    <label>
                        <%= t.subject_teacher %>
                    </label>
                    <select name="teacher_id">
                        <option value="">
                            <%= t.subject_no_teacher %>
                        </option>
                        <% teachers.forEach(teacher=> { %>
                            <option value="<%= teacher.id %>" <%= subject.teacher_id === teacher.id ? 'selected' : '' %>>
                                <%= teacher.name %>
                            </option>
                            <% }) %>
                    </select>
                </div>
                <button type="submit" class="btn-primary" style="width:100%;">
                    <%= t.save %>
                </button>
            </form>
        </div>
    </div>

    <%- include('../../partials/footer') %>
