<%- include('../../partials/header', { user: user }) %>

    <div class="main-content">
        <div class="page-header">
            <h2>Edit User</h2>
            <a href="/users" class="btn-secondary">
                <%= t.back %>
            </a>
        </div>

        <div class="glass-card form-container" style="max-width:600px; margin:0 auto;">
            <% if (error) { %>
                <div
                    style="background:#fee2e2;color:#b91c1c;padding:0.75rem 1rem;border-radius:8px;margin-bottom:1.5rem;border:1px solid #fecaca;">
                    ⚠️ <%= error %>
                </div>
                <% } %>
                    <form action="/users/<%= user_data.id %>/edit" method="POST">
                        <div class="form-group">
                            <label>
                                <%= t.user_name %> *
                            </label>
                            <input type="text" name="name" required placeholder="ex. Jean Dupont" value="<%= user_data.name %>">
                        </div>
                        <div class="form-group">
                            <label>
                                <%= t.user_email %> *
                            </label>
                            <input type="email" name="email" required placeholder="ex. jean@meshbi.com" value="<%= user_data.email %>">
                        </div>
                        <div class="form-group">
                            <label>
                                <%= t.user_password %> (Leave empty to keep current password)
                            </label>
                            <input type="password" name="password" placeholder="Enter new password to change">
                        </div>
                        <div class="form-group">
                            <label>
                                Role *
                            </label>
                            <select name="role" required>
                                <option value="admin" <%= user_data.role === 'admin' ? 'selected' : '' %>>Admin</option>
                                <option value="teacher" <%= user_data.role === 'teacher' ? 'selected' : '' %>>Teacher</option>
                                <option value="secretary" <%= user_data.role === 'secretary' ? 'selected' : '' %>>Secretary</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label>
                                Secondary Role (Optional)
                            </label>
                            <select name="secondary_role">
                                <option value="">-- None --</option>
                                <option value="admin" <%= user_data.secondary_role === 'admin' ? 'selected' : '' %>>Admin</option>
                                <option value="teacher" <%= user_data.secondary_role === 'teacher' ? 'selected' : '' %>>Teacher</option>
                                <option value="secretary" <%= user_data.secondary_role === 'secretary' ? 'selected' : '' %>>Secretary</option>
                            </select>
                        </div>
                        <button type="submit" class="btn-primary" style="width:100%;">
                            <%= t.save %>
                        </button>
                    </form>
        </div>
    </div>

    <%- include('../../partials/footer') %>
