<!DOCTYPE html>
<html lang="<%= lang %>">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= t.login_title %> — Meshbi School
    </title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet">
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Outfit', sans-serif;
        }

        body {
            height: 100vh;
            display: flex;
            background-color: #f3f4f6;
        }

        .login-split {
            display: flex;
            width: 100%;
            height: 100%;
        }

        .login-visual {
            flex: 1;
            background: linear-gradient(135deg, #4f46e5 0%, #06b6d4 100%);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            color: white;
            padding: 3rem;
            position: relative;
            overflow: hidden;
        }

        .visual-content {
            z-index: 2;
            text-align: center;
            max-width: 420px;
        }

        .visual-circle {
            position: absolute;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.1);
            z-index: 1;
        }

        .login-form-container {
            flex: 1;
            display: flex;
            justify-content: center;
            align-items: center;
            background: white;
            padding: 2rem;
        }

        .login-card {
            width: 100%;
            max-width: 420px;
            padding: 2rem;
        }

        h1.brand {
            font-size: 2.2rem;
            font-weight: 800;
            letter-spacing: -1px;
            margin-bottom: 0.75rem;
        }

        p.subtitle {
            font-size: 1rem;
            opacity: 0.9;
            line-height: 1.5;
            margin-bottom: 2rem;
        }

        .form-title {
            font-size: 1.75rem;
            color: #111827;
            font-weight: 700;
            margin-bottom: 0.5rem;
        }

        .form-subtitle {
            color: #6b7280;
            margin-bottom: 2rem;
            font-size: 0.95rem;
        }

        .input-group {
            margin-bottom: 1.25rem;
        }

        label {
            display: block;
            margin-bottom: 0.5rem;
            font-weight: 500;
            color: #374151;
            font-size: 0.9rem;
        }

        input {
            width: 100%;
            padding: 0.875rem;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            font-size: 1rem;
            transition: all 0.2s;
            background: #f9fafb;
        }

        input:focus {
            outline: none;
            border-color: #4f46e5;
            background: white;
            box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.1);
        }

        button {
            width: 100%;
            padding: 0.875rem;
            background-color: #4f46e5;
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            margin-top: 0.5rem;
            box-shadow: 0 4px 6px -1px rgba(79, 70, 229, 0.4);
        }

        button:hover {
            background-color: #4338ca;
            transform: translateY(-1px);
            box-shadow: 0 6px 8px -1px rgba(79, 70, 229, 0.5);
        }

        .alert-error {
            background: #fee2e2;
            color: #b91c1c;
            padding: 0.875rem 1rem;
            border-radius: 8px;
            margin-bottom: 1.5rem;
            font-size: 0.9rem;
            border: 1px solid #fecaca;
        }

        /* Language toggle */
        .lang-bar {
            position: fixed;
            top: 1rem;
            right: 1rem;
            z-index: 999;
            display: flex;
            gap: 0.5rem;
        }

        .lang-btn {
            padding: 0.4rem 0.9rem;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 700;
            text-decoration: none;
            border: 2px solid;
            transition: all 0.2s;
            cursor: pointer;
        }

        .lang-btn.active {
            background: #4f46e5;
            color: white;
            border-color: #4f46e5;
        }

        .lang-btn.inactive {
            background: white;
            color: #4f46e5;
            border-color: #4f46e5;
        }

        .lang-btn.inactive:hover {
            background: #4f46e5;
            color: white;
        }

        /* Year badge */
        .year-badge {
            background: rgba(255, 255, 255, 0.12);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.2);
            padding: 0.75rem 1.5rem;
            border-radius: 12px;
            margin-top: 2rem;
            font-size: 0.95rem;
        }

        @media (max-width: 768px) {
            body {
                flex-direction: column;
            }

            .login-split {
                flex-direction: column;
            }

            .login-visual {
                flex: 0 0 auto;
                min-height: 280px;
                padding: 2rem 1.5rem;
                justify-content: flex-start;
                padding-top: 3rem;
            }

            .visual-content {
                max-width: 100%;
            }

            .visual-circle {
                width: 150px !important;
                height: 150px !important;
            }

            .visual-circle:first-of-type {
                top: -40px !important;
                left: -40px !important;
            }

            .visual-circle:last-of-type {
                bottom: 20px !important;
                right: 20px !important;
                width: 120px !important;
                height: 120px !important;
            }

            h1.brand {
                font-size: 1.75rem;
            }

            p.subtitle {
                font-size: 0.9rem;
                margin-bottom: 1rem;
            }

            .year-badge {
                margin-top: 1rem;
                padding: 0.6rem 1.2rem;
                font-size: 0.85rem;
            }

            .login-form-container {
                flex: 1;
                padding: 1.5rem;
            }

            .login-card {
                padding: 1.5rem;
            }

            .form-title {
                font-size: 1.5rem;
            }

            .lang-bar {
                top: 0.75rem;
                right: 0.75rem;
            }
        }

        @media (max-width: 480px) {
            .login-visual {
                min-height: 240px;
                padding: 2rem 1rem;
            }

            h1.brand {
                font-size: 1.5rem;
                margin-bottom: 0.5rem;
            }

            p.subtitle {
                font-size: 0.85rem;
            }

            .login-form-container {
                padding: 1rem;
            }

            .login-card {
                padding: 1rem;
            }

            .form-title {
                font-size: 1.3rem;
            }

            .form-subtitle {
                font-size: 0.85rem;
            }

            input {
                padding: 0.75rem;
                font-size: 0.95rem;
            }

            button {
                padding: 0.75rem;
                font-size: 0.95rem;
            }

            label {
                font-size: 0.85rem;
            }

            .year-badge {
                padding: 0.5rem 1rem;
                font-size: 0.8rem;
            }

            .lang-bar {
                gap: 0.3rem;
            }

            .lang-btn {
                padding: 0.3rem 0.7rem;
                font-size: 0.75rem;
            }
        }
    </style>
</head>

<body>

    <!-- Language Toggle — visible on all devices -->
    <div class="lang-bar">
        <a href="/lang/en" class="lang-btn <%= lang === 'en' ? 'active' : 'inactive' %>">EN</a>
        <a href="/lang/fr" class="lang-btn <%= lang === 'fr' ? 'active' : 'inactive' %>">FR</a>
    </div>

    <div class="login-split">
        <!-- Left visual panel -->
        <div class="login-visual">
            <div class="visual-circle" style="width:320px;height:320px;top:-60px;left:-60px;"></div>
            <div class="visual-circle" style="width:220px;height:220px;bottom:60px;right:60px;"></div>
            <div class="visual-content">
                <h1 class="brand">🏫 Meshbi School</h1>
                <p class="subtitle">
                    <%= t.login_school_tagline %>
                </p>
                <div class="year-badge">
                    <strong>
                        <%= t.year %> : 2025 / 2026
                    </strong>
                </div>
            </div>
        </div>

        <!-- Right form panel -->
        <div class="login-form-container">
            <div class="login-card">
                <h2 class="form-title">
                    <%= t.login_welcome %>
                </h2>
                <p class="form-subtitle">
                    <%= t.login_subtitle %>
                </p>

                <% if (locals.error) { %>
                    <div class="alert-error">⚠️ <%= t.login_error %>
                    </div>
                    <% } %>

                <% if (query.timeout === 'true') { %>
                    <div class="alert-error" style="background:#fef3c7;color:#b45309;border-color:#fcd34d;">
                        ⏰ Your session has expired due to inactivity. Please login again.
                    </div>
                <% } %>

                        <form action="/auth/login" method="POST" autocomplete="off">
                            <div class="input-group">
                                <label for="email">
                                    <%= t.login_email %>
                                </label>
                                <input type="email" id="email" name="email" required
                                    placeholder="<%= t.login_email_placeholder %>" autocomplete="off">
                            </div>
                            <div class="input-group">
                                <label for="password">
                                    <%= t.login_password %>
                                </label>
                                <input type="password" id="password" name="password" required
                                    placeholder="<%= t.login_password_placeholder %>" autocomplete="new-password">
                            </div>
                            <button type="submit">
                                <%= t.login_btn %>
                            </button>
                        </form>

                        <p style="text-align:center;margin-top:1.5rem;font-size:0.85rem;color:#9ca3af;">
                            <%= t.login_help %>
                        </p>
            </div>
        </div>
    </div>
</body>

</html>