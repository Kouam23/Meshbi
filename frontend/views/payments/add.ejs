<%- include('../partials/header', { user: user }) %>

    <div class="main-content">
        <div class="page-header">
            <h2>Record Payment</h2>
            <a href="/students" class="btn-secondary">Back to Students</a>
        </div>

        <div class="glass-card form-container">
            <h3>Student: <%= student.name %> (<%= student.matricule %>)</h3>
            <hr style="margin: 1rem 0; opacity: 0.2;">

            <form action="/payments/add" method="POST">
                <input type="hidden" name="student_id" value="<%= student.id %>">

                <div class="form-group">
                    <label>Amount (FCFA)</label>
                    <input type="number" name="amount" required min="0" step="500">
                </div>

                <div class="form-group">
                    <label>Payment Type</label>
                    <select name="payment_type" required>
                        <option value="Pension">Pension</option>
                        <option value="Registration">Registration</option>
                        <option value="Other">Other</option>
                    </select>
                </div>

                <div class="form-group">
                    <label>Comments / Details</label>
                    <textarea name="comments" rows="3" class="form-control"
                        style="width:100%; padding: 0.5rem; border-radius: 4px; border: 1px solid #e5e7eb;"></textarea>
                </div>

                <button type="submit" class="btn-primary">Record Payment</button>
            </form>
        </div>
    </div>

    <%- include('../partials/footer') %>