<%- include('../partials/header', { user: user }) %>

    <div class="main-content">
        <div class="page-header">
            <h2>Edit Payment</h2>
            <a href="/payments/student/<%= student.id %>" class="btn-secondary">Back to Payment History</a>
        </div>

        <div class="glass-card form-container">
            <h3>Student: <%= student.name %> (<%= student.matricule %>)</h3>
            <hr style="margin: 1rem 0; opacity: 0.2;">

            <form action="/payments/<%= payment.id %>/edit" method="POST">
                <div class="form-group">
                    <label>Amount (FCFA)</label>
                    <input type="number" name="amount" required min="0" step="500" value="<%= payment.amount %>">
                </div>

                <div class="form-group">
                    <label>Payment Type</label>
                    <select name="payment_type" required>
                        <option value="Pension" <%= payment.payment_type === 'Pension' ? 'selected' : '' %>>Pension</option>
                        <option value="Registration" <%= payment.payment_type === 'Registration' ? 'selected' : '' %>>Registration</option>
                        <option value="Other" <%= payment.payment_type === 'Other' ? 'selected' : '' %>>Other</option>
                    </select>
                </div>

                <div class="form-group">
                    <label>Comments / Details</label>
                    <textarea name="comments" rows="3" class="form-control"
                        style="width:100%; padding: 0.5rem; border-radius: 4px; border: 1px solid #e5e7eb;"><%= payment.comments || '' %></textarea>
                </div>

                <button type="submit" class="btn-primary">Update Payment</button>
            </form>
        </div>
    </div>

    <%- include('../partials/footer') %>
