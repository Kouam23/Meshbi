<%- include('../partials/header', { user: user }) %>

    <div class="main-content">
        <div class="page-header">
            <h2>Edit Student</h2>
            <a href="/students/<%= student.id %>" class="btn-secondary">← Cancel</a>
        </div>

        <div class="glass-card form-container" style="max-width:720px; margin:0 auto;">
            <form action="/students/<%= student.id %>/edit" method="POST">
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:1.5rem;">
                    <div class="form-group">
                        <label>Full Name *</label>
                        <input type="text" name="name" value="<%= student.name %>" required>
                    </div>
                    <div class="form-group">
                        <label>Class/Level *</label>
                        <select name="level" required>
                            <% ['Form 1','Form 2','Form 3','Form 4','Form 5','Lower Sixth','Upper Sixth'].forEach(l=> {
                                %>
                                <option value="<%= l %>" <%=student.level===l ? 'selected' : '' %>><%= l %>
                                </option>
                                <% }) %>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Gender</label>
                        <select name="gender">
                            <option value="">-- Select --</option>
                            <option value="Male" <%=student.gender==='Male' ? 'selected' : '' %>>Male</option>
                            <option value="Female" <%=student.gender==='Female' ? 'selected' : '' %>>Female</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Date of Birth</label>
                        <input type="date" name="dob" value="<%= student.dob || '' %>">
                    </div>
                    <div class="form-group">
                        <label>Place of Birth</label>
                        <input type="text" name="pob" value="<%= student.pob || '' %>">
                    </div>
                    <div class="form-group">
                        <label>Phone</label>
                        <input type="text" name="phone" value="<%= student.phone || '' %>">
                    </div>
                    <div class="form-group" style="grid-column: span 2;">
                        <label>Address</label>
                        <input type="text" name="address" value="<%= student.address || '' %>">
                    </div>
                    <div class="form-group">
                        <label>Parent/Guardian Name</label>
                        <input type="text" name="parent_name" value="<%= student.parent_name || '' %>">
                    </div>
                    <div class="form-group">
                        <label>Parent/Guardian Phone</label>
                        <input type="text" name="parent_phone" value="<%= student.parent_phone || '' %>">
                    </div>
                </div>

                <button type="submit" class="btn-primary" style="width:100%; margin-top:1rem;">Save Changes</button>
            </form>
        </div>
    </div>

    <%- include('../partials/footer') %>