<%- include('../partials/header', { user: user }) %>

    <div class="main-content">
        <div class="page-header">
            <h2>
                <%= t.students_title %>
            </h2>
            <% if (user.role==='admin' || user.role==='secretary' ) { %>
                <a href="/students/add" class="btn-primary">
                    <%= t.students_register %>
                </a>
                <% } %>
        </div>

        <div class="glass-card" style="padding:0; overflow:hidden;">
            <% if (students.length===0) { %>
                <div style="padding:3rem; text-align:center; color:var(--text-muted);">
                    <p style="font-size:1.2rem;">
                        <%= t.students_empty %>
                    </p>
                    <% if (user.role !=='teacher' ) { %>
                        <a href="/students/add" class="btn-primary" style="margin-top:1rem;display:inline-block;">
                            <%= t.students_register_first %>
                        </a>
                        <% } %>
                </div>
                <% } else { %>
                    <div class="table-wrapper">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>
                                        <%= t.student_col_matricule %>
                                    </th>
                                    <th>
                                        <%= t.student_col_name %>
                                    </th>
                                    <th>
                                        <%= t.student_col_level %>
                                    </th>
                                    <th>
                                        <%= t.student_col_phone %>
                                    </th>
                                    <th>
                                        <%= t.student_col_actions %>
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                <% students.forEach(student=> { %>
                                    <tr>
                                        <td><span class="badge badge-primary">
                                                <%= student.matricule %>
                                            </span></td>
                                        <td><strong>
                                                <%= student.name %>
                                            </strong></td>
                                        <td>
                                            <%= student.level %>
                                        </td>
                                        <td style="color:var(--text-muted)">
                                            <%= student.phone || t.na %>
                                        </td>
                                        <td>
                                            <a href="/students/<%= student.id %>" class="btn-secondary btn-sm">
                                                <%= t.view %>
                                            </a>
                                            <% if (user.role==='admin' || user.role==='secretary' ) { %>
                                                <a href="/students/<%= student.id %>/edit" class="btn-secondary btn-sm">
                                                    <%= t.edit %>
                                                </a>
                                                <a href="/payments/add?student_id=<%= student.id %>"
                                                    class="btn-secondary btn-sm" style="color:var(--secondary-color)">
                                                    <%= t.student_add_payment %>
                                                </a>
                                                <% } %>
                                        </td>
                                    </tr>
                                    <% }) %>
                            </tbody>
                        </table>
                    </div>
                    <% } %>
        </div>
    </div>

    <%- include('../partials/footer') %>